# =============================================================================
# AI Email Agent — .env.example
# Copy this file to .env and fill in your values.
# =============================================================================

# AI Provider: "huggingface" (default, free) or "claude"
AI_PROVIDER=huggingface

# HuggingFace Inference Router  (get token at https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here
HF_MODEL=Qwen/Qwen2.5-7B-Instruct:together
HF_API_URL=https://router.huggingface.co/v1/chat/completions
HF_MAX_RETRIES=3
HF_RETRY_DELAY=10
HF_TIMEOUT=120

# Anthropic Claude  (only needed if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Gmail OAuth Paths
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Gmail Push Notifications  (see PUSH_SETUP.md for one-time GCP setup)
PUBSUB_TOPIC=projects/your-gcp-project-id/topics/your-topic-name
WEBHOOK_BASE_URL=https://your-ngrok-or-domain-url.com
GMAIL_WATCH_RENEWAL_HOURS=23

# User Details
USER_NAME="Your Full Name"
USER_EMAIL=your_email@gmail.com

# Agent Behaviour
AUTO_REPLY_LABEL=auto-replied
REPLY_TONE=professional
ALLOWED_DOMAINS=gmail.com,charusat.edu.in
MAX_WORKERS=3
STARTUP_CATCHUP_LIMIT=50

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000
